/// selected value changes.
class {{ selector_class }}<R> extends StatefulWidget {
  const {{ selector_class }}({
    super.key,
    required this.selector,
    required this.builder,
    this.child,
    this.equals,
  });

  final R Function({{ state_type }} state) selector;
  final Widget Function(BuildContext context, R value, Widget? child) builder;
  final Widget? child;
