final class RouteNavigation<T extends Object> {
  const RouteNavigation(this._router, this.route);

  final DustRouterController<T> _router;
  final T route;

  void go() => _router.go(route);
  void push() => _router.push(route);
  void replace() => _router.replace(route);
}
