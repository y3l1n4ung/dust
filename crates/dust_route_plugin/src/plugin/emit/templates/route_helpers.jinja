extension DustRouterContext on BuildContext {
  DustRouterController<AppRoutePath> get router =>
      DustRouter.of<AppRoutePath>(this);
  AppRoutesNavigation get routes => AppRoutesNavigation(router);
}

final class AppRoutesNavigation {
