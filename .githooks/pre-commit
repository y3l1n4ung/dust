#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

echo "==> Running Dust pre-commit checks"

run_without_git_env() {
  (
    unset $(git rev-parse --local-env-vars)
    "$@"
  )
}

./scripts/rust/format.sh --check
run_without_git_env ./scripts/dart/format.sh --check
run_without_git_env ./scripts/flutter/format.sh --check
run_without_git_env ./scripts/dart/format.sh --check --examples
run_without_git_env ./scripts/flutter/format.sh --check --examples
./scripts/rust/lint.sh
run_without_git_env ./scripts/dart/lint.sh
run_without_git_env ./scripts/flutter/lint.sh
run_without_git_env ./scripts/dart/lint.sh --examples
run_without_git_env ./scripts/flutter/lint.sh --examples
./scripts/rust/test.sh
run_without_git_env ./scripts/dart/test.sh
run_without_git_env ./scripts/flutter/test.sh
run_without_git_env ./scripts/dart/test.sh --examples
run_without_git_env ./scripts/flutter/test.sh --examples

echo "==> Pre-commit checks passed"
